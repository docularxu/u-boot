// SPDX-License-Identifier: GPL-2.0+ OR MIT
/*
 * U-Boot specifics for the Banana Pi BPI-F3 (Spacemit K1).
 *
 * Auto-included by the build on top of
 * dts/upstream/src/riscv/spacemit/k1-bananapi-f3.dts.
 */

#include <dt-bindings/clock/spacemit,k1-syscon.h>
#include "binman.dtsi"

/ {
	/*
	 * The kernel BPI-F3 dts intentionally has no memory@0 — kernels
	 * obtain RAM extents from the bootloader. U-Boot needs the memory
	 * node early, so carry it here.
	 */
	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x00000000 0x00000000 0x80000000>;
	};
};

&uart0 {
	bootph-pre-ram;
};

&osc_32k {
	bootph-pre-ram;
};

&vctcxo_1m {
	bootph-pre-ram;
};

&vctcxo_3m {
	bootph-pre-ram;
};

&vctcxo_24m {
	bootph-pre-ram;
};

&syscon_mpmu {
	bootph-pre-ram;
};

&pll {
	bootph-pre-ram;
};

&syscon_apmu {
	bootph-pre-ram;
};

/*
 * U-Boot's clock driver resolves APBC parents through DT, while the kernel
 * derives pll1_d78_31p5 / pll1_d4 internally with clk_register_fixed_factor.
 * Extend the parent list here so the SPL/U-Boot APBC driver finds them.
 */
&syscon_apbc {
	clocks = <&osc_32k>, <&vctcxo_1m>, <&vctcxo_3m>, <&vctcxo_24m>,
		 <&syscon_mpmu CLK_PLL1_31P5>, <&pll CLK_PLL1_D4>;
	clock-names = "osc", "vctcxo_1m", "vctcxo_3m", "vctcxo_24m",
		      "pll1_d78_31p5", "pll1_d4";
	bootph-pre-ram;
};

&i2c2 {
	bootph-pre-ram;

	eeprom@50 {
		bootph-pre-ram;
	};
};

/*
 * The kernel pmic@41 nodes use the standard regulator-* properties only;
 * U-Boot's regulator framework looks up suppliers by `regulator-name`.
 * Carry the U-Boot-specific names (vdd_core / vdd_1v8 / vdd_1v8_mmc) here
 * so SPL can program the bucks that DDR training depends on.
 */
&i2c8 {
	bootph-pre-ram;

	pmic@41 {
		bootph-pre-ram;

		regulators {
			buck1 {
				regulator-name = "vdd_core";
				bootph-pre-ram;
			};

			aldo1 {
				regulator-name = "vdd_1v8_mmc";
				bootph-pre-ram;
			};
		};
	};
};

&buck3_1v8 {
	regulator-name = "vdd_1v8";
	bootph-pre-ram;
};

&binman {
	u-boot-spl-ddr {
		type = "section";
		filename = "u-boot-spl-ddr.bin";
		pad-byte = <0xff>;

		u-boot-spl {
		};

		ddr-fw {
			type = "blob";
			filename = "ddr_fw.bin";
			align = <64>;
		};

		u-boot-any {
			type = "section";
			size = <0>;
			offset = <0>;
		};
	};
};
