/dts-v1/;

#include "k1.dtsi"
#include "k1-spm8821.dtsi"

/ {
	model = "spacemit k1 spl";

	aliases {
		console = &uart0;
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootph-all;
	};

	binman {
		section {
			filename = "u-boot-spl-ddr.bin";
			pad-byte = <0xff>;
			align-size = <4>;
			align = <4>;

			spl_section: section {
				type = "section";
				size = <CONFIG_SPL_DDR_FIRMWARE_OFFSET>;

				u-boot-spl-nodtb {
					type = "blob";
					filename = "spl/u-boot-spl.bin";
					align-end = <4>;
				};

				u-boot-spl-dtb {
					type = "blob";
				        filename = "spl/u-boot-spl.dtb";
					align-end = <4>;
				};
			};

			ddr_fw: ddr-firmware {
				type = "blob";
				offset = <CONFIG_SPL_DDR_FIRMWARE_OFFSET>;
				filename = "ddr_fw.bin";
				optional;
				align-end = <4>;
			};
		};
	};
};

&vctcxo_1m {
	status = "okay";
	bootph-pre-ram;
};

&vctcxo_24m {
	status = "okay";
	bootph-pre-ram;
};

&vctcxo_3m {
	status = "okay";
	bootph-pre-ram;
};

&osc_32k {
	status = "okay";
	bootph-pre-ram;
};

&soc {
	bootph-all;
	system-controller@d4015000 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};
	system-controller@d4050000 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};
	clock-controller@d4090000 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};
	system-controller@d4282800 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};

	i2c@d4012000 {		/* i2c2 */
		status = "okay";
		bootph-pre-ram;
		eeprom: eeprom {
			compatible = "atmel,24c02";
			reg = <0x50>;
			status = "okay";
			bootph-pre-ram;
		};
	};

	i2c@d401d800 {		/* i2c8 */
		status = "okay";
		bootph-pre-ram;
		spm8821: pmic {
			compatible = "spacemit,spm8821";
			reg = <0x41>;
			//bus = <8>;
			status = "okay";
			bootph-pre-ram;
		};
	};

	reset-controller@d4050000 {
		status = "okay";
		bootph-pre-ram;
	};
};

&uart0 {
	status = "okay";
	bootph-pre-ram;
};
