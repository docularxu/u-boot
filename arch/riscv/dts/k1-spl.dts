/dts-v1/;
#include "k1.dtsi"
#include "binman.dtsi"

/ {
	model = "spacemit k1 spl";

	aliases {
		console = &uart0;
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootph-all;
	};
};

&vctcxo_1m {
	status = "okay";
	bootph-pre-ram;
};

&vctcxo_24m {
	status = "okay";
	bootph-pre-ram;
};

&vctcxo_3m {
	status = "okay";
	bootph-pre-ram;
};

&osc_32k {
	status = "okay";
	bootph-pre-ram;
};


&soc {
	bootph-all;
	system-controller@d4015000 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};
	system-controller@d4050000 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};
	clock-controller@d4090000 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};
	system-controller@d4282800 {
		status = "okay";
		bootph-all;
		bootph-pre-ram;
	};
};

&uart0 {
	status = "okay";
	bootph-pre-ram;
};
